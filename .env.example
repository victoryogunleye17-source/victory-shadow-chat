# ============================================================
# SHADOW CHAT — Environment Variables
# Copy this file to .env (local dev) and add the same keys
# in Vercel → Project → Settings → Environment Variables
# ============================================================

# --- Database (Neon Postgres — works natively with Vercel) ---
# Get this from https://neon.tech after creating a free project
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# --- Owner / Founder account ---
OWNER_EMAIL=victoryogunleye17@gmail.com

# --- Email (Resend — https://resend.com, free tier) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="Shadow Chat <noreply@yourdomain.com>"
APP_URL=https://your-app.vercel.app

# --- Real-time (Pusher — https://pusher.com, free tier: 200k msgs/day) ---
PUSHER_APP_ID=xxxxxxx
PUSHER_KEY=xxxxxxxxxxxxxxxxxxxx
PUSHER_SECRET=xxxxxxxxxxxxxxxxxxxx
PUSHER_CLUSTER=mt1

# --- File Storage (Vercel Blob) ---
# Created automatically when you run: vercel blob store add
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx

# --- Rate Limiting (Upstash Redis — https://upstash.com, free tier) ---
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxx
